@page "/rapid-rate"
@using BarBrain.Web.Components
@using BarBrain.Web.Services
@inject HttpClient Http
@inject NavigationManager Nav
@inject UserState User
@inject BadgeNotifier Badges

<PageTitle>Rapid rate — BarBrain</PageTitle>

<h1>Rapid rate</h1>
<p class="bb-muted">Tell it what you already know. Every rating sharpens your palate profile.</p>

@if (User.Me is { CanRate: false })
{
    <div class="bb-card" data-testid="rr-verify-notice">
        <p>Verify your email to rate — the link is in your inbox. Browsing still works.</p>
    </div>
}

<div class="bb-pill-row" role="group" aria-label="Category">
    @foreach (var (value, label) in CategoryOptions)
    {
        <button type="button" class="bb-pill @(_category == value ? "is-active" : "")"
                aria-pressed="@(_category == value)" data-testid="rr-cat-@(value ?? "all")"
                @onclick="() => SetCategoryAsync(value)">@label</button>
    }
</div>
<div class="bb-pill-row" role="group" aria-label="Filter and order">
    <button type="button" class="bb-pill @(_unratedOnly ? "is-active" : "")"
            aria-pressed="@_unratedOnly" data-testid="rr-unrated"
            @onclick="ToggleUnratedAsync">Haven't rated</button>
    <button type="button" class="bb-pill @(_sort == "popular" ? "is-active" : "")"
            aria-pressed="@(_sort == "popular")" data-testid="rr-sort-popular"
            @onclick="@(() => SetSortAsync("popular"))">Popular</button>
    <button type="button" class="bb-pill @(_sort == "name" ? "is-active" : "")"
            aria-pressed="@(_sort == "name")" data-testid="rr-sort-name"
            @onclick="@(() => SetSortAsync("name"))">A–Z</button>
</div>

@if (_loadError is not null)
{
    <p class="bb-form__error" role="alert">@_loadError</p>
}

@if (_items.Count > 0)
{
    <ul class="bb-rr-list" data-testid="rr-list">
        @foreach (var item in _items)
        {
            var state = StateOf(item);
            @* A drink being rated is a BEVERAGE object → amber accent. *@
            <li class="bb-rr-card" data-testid="rr-card">
                <div class="bb-rr-card__info">
                    <span class="bb-rr-card__name">@item.Name</span>
                    <span class="bb-rr-card__detail">
                        @item.ProducerName · @(item.StyleName ?? Cap(item.Category))@(item.Abv is { } abv ? $" · {abv:0.#}%" : "")
                    </span>
                    @if (item.PublicRatingCount > 0)
                    {
                        <span class="bb-rr-card__detail">@item.PublicRatingCount rating@(item.PublicRatingCount == 1 ? "" : "s")</span>
                    }
                </div>
                <div class="bb-rr-card__rate">
                    <StarRating Value="@state.Value" Interactive="@(User.Me is { CanRate: true })" Size="22"
                                ValueChanged="v => RateAsync(item, v)" />
                    <div class="bb-rr-card__row">
                        @if (state.Saving)
                        {
                            <span class="bb-rr-status">Saving…</span>
                        }
                        else if (state.Error is not null)
                        {
                            <span class="bb-rr-status bb-rr-status--error" role="alert" data-testid="rr-error">@state.Error</span>
                        }
                        else if (state.Saved)
                        {
                            @* The profile learned something → intelligence → teal. *@
                            <span class="bb-rr-status bb-rr-status--noted" data-testid="rr-saved">Noted</span>
                        }
                        else if (item.MyLatestValue is { } prior)
                        {
                            <span class="bb-rr-status">Your latest: @prior.ToString("0.0")</span>
                        }
                        <button type="button" class="bb-rr-private @(state.Private ? "is-on" : "")"
                                aria-pressed="@state.Private" data-testid="rr-private"
                                aria-label="Keep your rating of @item.Name private"
                                @onclick="() => TogglePrivateAsync(item)">Private</button>
                    </div>
                </div>
            </li>
        }
    </ul>
    @if (_items.Count < _total)
    {
        <button type="button" class="bb-btn bb-btn--block" data-testid="rr-more"
                disabled="@_loading" @onclick="LoadMoreAsync">
            @(_loading ? "Loading…" : "Show more")
        </button>
    }
}
else if (_loading)
{
    <p class="bb-muted">Pouring the list…</p>
}
else if (_unratedOnly)
{
    <div class="bb-card" data-testid="rr-empty">
        <p>You've weighed in on everything here.</p>
        <p class="bb-muted">Your palate profile is sharper for it — <a href="/feed">see what it learned in your feed</a>.</p>
    </div>
}
else
{
    <div class="bb-card" data-testid="rr-empty">
        <p>The catalog is still filling in here.</p>
        <p class="bb-muted">Try another category, or <a href="/search">search for anything</a>.</p>
    </div>
}

@code {
    private sealed class CardState
    {
        public decimal Value;
        public bool Saving, Saved;
        public string? Error;
        public bool Private;         // applies to the next post from this card
        public Guid? LastRatingId;   // from the POST's 201 body — enables visibility PATCH
    }

    private static readonly (string? Value, string Label)[] CategoryOptions =
        [(null, "All"), ("beer", "Beer"), ("whiskey", "Whiskey"), ("wine", "Wine")];

    private readonly List<RapidRateItem> _items = [];
    private readonly HashSet<Guid> _seen = [];
    private readonly Dictionary<Guid, CardState> _state = [];

    private string? _category;
    private bool _unratedOnly;
    private string _sort = "popular";
    private int _page = 1;
    private int _total;
    private bool _loading;
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        await User.EnsureLoadedAsync();
        if (!User.IsSignedIn)
        {
            Nav.NavigateTo("/login");
            return;
        }
        await LoadAsync(reset: true);
    }

    private CardState StateOf(RapidRateItem item)
        => _state.TryGetValue(item.Id, out var s)
            ? s
            : _state[item.Id] = new CardState { Value = item.MyLatestValue ?? 0 };

    private async Task LoadAsync(bool reset)
    {
        if (reset)
        {
            _page = 1;
            _items.Clear();
            _seen.Clear();
            _total = 0;
        }
        _loading = true;
        _loadError = null;
        try
        {
            var url = $"api/rapidrate/drinks?page={_page}&sort={_sort}"
                + (_category is not null ? $"&category={_category}" : "")
                + (_unratedOnly ? "&unratedOnly=true" : "");
            var result = await Http.GetFromJsonAsync<PagedResult<RapidRateItem>>(url);
            if (result is not null)
            {
                _total = result.Total;
                // Mid-list ratings shift the server-side unrated window, so a
                // later page can repeat a drink — de-dupe by id and move on.
                foreach (var item in result.Items)
                    if (_seen.Add(item.Id))
                        _items.Add(item);
            }
        }
        catch
        {
            _loadError = "Couldn't reach the server. Check your connection and try again.";
        }
        _loading = false;
    }

    private Task SetCategoryAsync(string? category)
    {
        _category = category;
        return LoadAsync(reset: true);
    }

    private Task ToggleUnratedAsync()
    {
        _unratedOnly = !_unratedOnly;
        return LoadAsync(reset: true);
    }

    private Task SetSortAsync(string sort)
    {
        if (_sort == sort) return Task.CompletedTask;
        _sort = sort;
        return LoadAsync(reset: true);
    }

    private Task LoadMoreAsync()
    {
        _page++;
        return LoadAsync(reset: false);
    }

    private async Task RateAsync(RapidRateItem item, decimal value)
    {
        var state = StateOf(item);
        state.Value = value;
        state.Saving = true;
        state.Saved = false;
        state.Error = null;
        StateHasChanged();
        try
        {
            // The existing rating pipeline, untouched: a rapid-rate rating is
            // just a rating (origin user, Home Bar default — ADR-015).
            using var response = await Http.PostAsJsonAsync("api/ratings",
                new RateRequest(item.Id, value, null,
                    state.Private ? "private" : "public", "home_bar", null, "user"));
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<RatingDto>();
                state.LastRatingId = saved?.Id;
                state.Saved = true;
                await Badges.CheckAsync(); // award toast, if this rating earned one
            }
            else
            {
                var error = await ApiErrors.ReadAsync(response);
                state.Error = error?.Message ?? "Didn't save — tap it again.";
            }
        }
        catch
        {
            state.Error = "Didn't save — tap it again.";
        }
        state.Saving = false;
    }

    private async Task TogglePrivateAsync(RapidRateItem item)
    {
        var state = StateOf(item);
        state.Private = !state.Private;
        if (state.LastRatingId is not { } ratingId)
            return; // nothing saved yet — the toggle rides on the next post

        try
        {
            using var response = await Http.PatchAsJsonAsync($"api/ratings/{ratingId}",
                new RatingUpdateRequest(null, state.Private ? "private" : "public"));
            if (!response.IsSuccessStatusCode)
            {
                state.Private = !state.Private; // revert — the server said no
                var error = await ApiErrors.ReadAsync(response);
                state.Error = error?.Message ?? "Couldn't change visibility — try again.";
            }
        }
        catch
        {
            state.Private = !state.Private;
            state.Error = "Couldn't change visibility — try again.";
        }
    }

    private static string Cap(string s) => s.Length == 0 ? s : char.ToUpperInvariant(s[0]) + s[1..];
}
