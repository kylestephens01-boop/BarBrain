@* Palate radar (DESIGN-REFERENCE Screen 3/7). Always 8 spokes; 3 concentric
   rings in surface stroke; filled area + line + vertex dots in synapse — the
   chart depicts INTELLIGENCE about the user, so it's teal by grammar. *@

<svg viewBox="0 0 240 240" width="@Size" height="@Size" role="img"
     aria-label="Palate radar: @string.Join(", ", LabelsWithValues())">
    @foreach (var ring in new[] { 1 / 3.0, 2 / 3.0, 1.0 })
    {
        <polygon points="@RingPoints(ring)" fill="none"
                 stroke="var(--bb-surface)" stroke-width="1" />
    }
    @for (var i = 0; i < Spokes; i++)
    {
        var (x, y) = Point(i, 1.0);
        <line x1="120" y1="120" x2="@F(x)" y2="@F(y)"
              stroke="var(--bb-surface)" stroke-width="1" />
    }
    @if (HasValues)
    {
        <polygon points="@ValuePoints()"
                 fill="var(--bb-synapse)" fill-opacity="0.25"
                 stroke="var(--bb-synapse)" stroke-width="1.5" />
        @for (var i = 0; i < Spokes; i++)
        {
            var (x, y) = Point(i, Norm(i));
            <circle cx="@F(x)" cy="@F(y)" r="3.5" fill="var(--bb-synapse)" />
        }
    }
    @* Razor reserves <text>; emit the SVG label elements as raw markup. *@
    @for (var i = 0; i < Spokes; i++)
    {
        var (x, y) = Point(i, 1.22);
        @((MarkupString)($"<text x=\"{F(x)}\" y=\"{F(y)}\" font-size=\"10\" fill=\"var(--bb-text-muted)\" "
            + "text-anchor=\"middle\" dominant-baseline=\"middle\" font-family=\"var(--bb-font-ui)\">"
            + System.Net.WebUtility.HtmlEncode(LabelAt(i)) + "</text>"))
    }
</svg>

@code {
    private const int Spokes = 8;
    private const double Radius = 88;

    /// <summary>8 attribute display names, dim order.</summary>
    [Parameter, EditorRequired] public IReadOnlyList<string> Labels { get; set; } = [];
    /// <summary>8 values on the 0–10 display scale, dim order.</summary>
    [Parameter, EditorRequired] public IReadOnlyList<float> Values { get; set; } = [];
    [Parameter] public int Size { get; set; } = 240;

    private bool HasValues => Values.Count == Spokes;

    private double Norm(int i) => Math.Clamp(Values[i] / 10.0, 0, 1);

    private string LabelAt(int i) => i < Labels.Count ? Labels[i] : "";

    private static (double X, double Y) Direction(int i)
    {
        var angle = (-90 + i * 360.0 / Spokes) * Math.PI / 180.0;
        return (Math.Cos(angle), Math.Sin(angle));
    }

    private static (double X, double Y) PointAt(int i, double fraction)
    {
        var (dx, dy) = Direction(i);
        return (120 + Radius * fraction * dx, 120 + Radius * fraction * dy);
    }

    private (double X, double Y) Point(int i, double fraction) => PointAt(i, fraction);

    private string RingPoints(double fraction)
        => string.Join(" ", Enumerable.Range(0, Spokes)
            .Select(i => PointAt(i, fraction))
            .Select(p => $"{F(p.X)},{F(p.Y)}"));

    private string ValuePoints()
        => string.Join(" ", Enumerable.Range(0, Spokes)
            .Select(i => PointAt(i, Norm(i)))
            .Select(p => $"{F(p.X)},{F(p.Y)}"));

    private IEnumerable<string> LabelsWithValues()
        => HasValues
            ? Enumerable.Range(0, Math.Min(Labels.Count, Spokes)).Select(i => $"{Labels[i]} {Values[i]:0.0}")
            : Labels;

    private static string F(double v) => v.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
}
