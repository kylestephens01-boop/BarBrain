# Keep the build context small and reproducible — never ship host build output.
**/bin/
**/obj/
**/.vs/
**/node_modules/
**/.git/
**/.github/

# Local secrets / env
**/.env
infra/.env

# Test + tooling artifacts
tests/e2e/test-results/
tests/e2e/playwright-report/
**/*.user

# Docs aren't needed inside images — EXCEPT the data-source license registry,
# which the api embeds so the ADR-024 import gate is enforced in-container.
docs/
!docs/DATA-SOURCES.md
