@inherits LayoutComponentBase
@using BarBrain.Web.Components
@using BarBrain.Web.Services
@inject UserState User

<div class="bb-app">
    <VerificationBanner />
    <OfflineBanner />
    <main class="bb-main">
        @Body
        <footer class="bb-footer" data-testid="site-footer">
            <p class="bb-footer__age">BarBrain is for adults 21 and over. Drink responsibly.</p>
            <nav class="bb-footer__links" aria-label="Legal">
                <a href="/legal/terms">Terms</a>
                <a href="/legal/privacy">Privacy</a>
                <a href="/legal/contact">Contact &amp; reporting</a>
            </nav>
        </footer>
    </main>
    <BadgeToasts />
    <InstallPrompt />
    <NavBar />
</div>

@code {
    protected override Task OnInitializedAsync() => User.EnsureLoadedAsync();
}
