@page "/admin/merge-queue"
@using BarBrain.Shared.Contracts
@using System.Net.Http.Json
@inject HttpClient Http

<PageTitle>BarBrain — Merge queue</PageTitle>

@* Admin stub (Sprint 1 scope: "UI beyond admin queue stub" is out of scope).
   Reviews suspected duplicate producers/drinks. Amber = beverage objects per
   the two-temperature grammar; controls stay neutral. Auth is the Sprint 0
   token stub: the token field sets the X-Admin-Token header. *@

<main class="merge-admin">
    <h1>Merge queue</h1>
    <p class="merge-admin__hint">
        Suspected duplicates from entity resolution. Approving redirects the
        source entry into the target; rejecting remembers the pair and never
        proposes it again.
    </p>

    <form class="merge-admin__controls" @onsubmit="LoadAsync" @onsubmit:preventDefault>
        <label for="admin-token">Admin token</label>
        <input id="admin-token" data-testid="admin-token-input" type="password"
               @bind="_token" autocomplete="off"
               placeholder="X-Admin-Token (blank in local dev)" />
        <button type="submit" data-testid="load-btn" disabled="@_loading">
            @(_loading ? "Loading…" : "Load pending")
        </button>
    </form>

    @if (_error is not null)
    {
        <p class="merge-admin__error" role="alert" data-testid="merge-error">@_error</p>
    }

    @if (_candidates is { Count: 0 })
    {
        <p data-testid="merge-empty">No pending candidates. The queue is clear.</p>
    }
    else if (_candidates is not null)
    {
        <table class="merge-admin__table" data-testid="merge-table">
            <caption>Pending merge candidates (highest similarity first)</caption>
            <thead>
                <tr>
                    <th scope="col">Type</th>
                    <th scope="col">Source (merges away)</th>
                    <th scope="col">Target (survives)</th>
                    <th scope="col">Similarity</th>
                    <th scope="col">Evidence</th>
                    <th scope="col"><span class="visually-hidden">Actions</span></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var candidate in _candidates)
                {
                    <tr data-testid="merge-row">
                        <td>@candidate.EntityType</td>
                        <td>
                            <span class="merge-admin__name">@candidate.Source.Name</span>
                            <span class="merge-admin__detail">@candidate.Source.Detail</span>
                        </td>
                        <td>
                            <span class="merge-admin__name">@candidate.Target.Name</span>
                            <span class="merge-admin__detail">@candidate.Target.Detail</span>
                        </td>
                        <td>@candidate.Similarity.ToString("0.00")</td>
                        <td>@candidate.Reason</td>
                        <td class="merge-admin__actions">
                            <button data-testid="approve-btn" disabled="@_loading"
                                    @onclick="() => DecideAsync(candidate.Id, approve: true)">
                                Approve
                            </button>
                            <button data-testid="reject-btn" class="merge-admin__reject" disabled="@_loading"
                                    @onclick="() => DecideAsync(candidate.Id, approve: false)">
                                Reject
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</main>

@code {
    private List<MergeCandidateDto>? _candidates;
    private string _token = "";
    private string? _error;
    private bool _loading;

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, "api/admin/merge-queue/?status=pending");
            AddToken(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                _error = $"Load failed: {(int)response.StatusCode} {response.ReasonPhrase}";
                return;
            }
            _candidates = await response.Content.ReadFromJsonAsync<List<MergeCandidateDto>>();
        }
        catch (Exception ex)
        {
            _error = $"Load failed: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task DecideAsync(Guid id, bool approve)
    {
        _loading = true;
        _error = null;
        try
        {
            var action = approve ? "approve" : "reject";
            using var request = new HttpRequestMessage(HttpMethod.Post, $"api/admin/merge-queue/{id}/{action}");
            AddToken(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                _error = $"{action} failed: {(int)response.StatusCode} {response.ReasonPhrase}";
                return;
            }
            _candidates?.RemoveAll(c => c.Id == id);
        }
        catch (Exception ex)
        {
            _error = $"Decision failed: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void AddToken(HttpRequestMessage request)
    {
        if (!string.IsNullOrWhiteSpace(_token))
            request.Headers.Add("X-Admin-Token", _token);
    }
}
