# Caddy serves the Blazor WASM static site and reverse-proxies API routes to the
# `api` service so the SPA is same-origin with the API (no CORS). Local dev runs
# plain HTTP on :80 (mapped to host :5000); TLS in prod is fronted by Cloudflare.
#
# Dev-site privacy (brand gate, until the trademark knockout clears): the PRIMARY
# mechanism is Cloudflare Access on the dev hostname (HUMAN-CHECKLIST 3) — it
# gates at the edge and does NOT affect origin localhost health checks. If you
# prefer an origin-side fallback, uncomment the basic_auth block below. It
# exempts /health and /version so the deploy health check still works. Generate
# the hash with:  docker run --rm caddy caddy hash-password --plaintext '<pw>'
:80 {
	root * /srv
	encode gzip zstd

	# --- Security headers (Sprint 7 hardening) -------------------------------
	# CSP notes: 'wasm-unsafe-eval' is what Blazor WASM needs to run;
	# 'unsafe-inline' in script-src is a DOCUMENTED COMPROMISE for the
	# build-injected import map + the one-line service-worker registration in
	# index.html (follow-up: hash the import map at publish and drop it).
	# challenges.cloudflare.com is Turnstile (script + frame + connect) — the
	# one legitimate external origin. HSTS is safe on the Access-gated dev
	# host and required once Cloudflare TLS moves to Full for launch.
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://challenges.cloudflare.com; connect-src 'self' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'"
		Strict-Transport-Security "max-age=15552000"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(self), camera=(), microphone=(), payment=(), usb=()"
		-Server
	}

	# --- Optional origin-side dev privacy (fallback to Cloudflare Access) ---
	# @diagnostics path /health /version
	# @protected not path /health /version
	# basic_auth @protected {
	#     barbrain <BCRYPT_HASH_HERE>
	# }

	# API surface → api container. Keep this list in sync with the API routes.
	@api path /api/* /health /version
	handle @api {
		reverse_proxy api:8080
	}

	# Everything else is the SPA: serve the file or fall back to index.html.
	handle {
		try_files {path} /index.html
		file_server
	}

	# Don't cache the WASM bootstrap/service worker; let fingerprinted assets cache.
	@nocache path /index.html /service-worker.js /manifest.webmanifest
	header @nocache Cache-Control "no-cache"
}
