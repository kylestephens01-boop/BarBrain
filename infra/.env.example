# Copy to infra/.env (gitignored) for local docker compose. NEVER commit .env.
# Secrets in prod live in the VPS .env / GitHub Actions secrets (Hard Rule 8).

# Postgres password for the local stack.
POSTGRES_PASSWORD=barbrain

# Stub admin token gating /api/admin/* (Sprint 0 auth is stubbed). Leave blank
# locally to allow admin calls with a logged warning; set it to require the
# X-Admin-Token header.
ADMIN_TOKEN=

# ASP.NET Core environment for the api container.
ASPNETCORE_ENVIRONMENT=Development

# Mock Google/Apple sign-in for local dev + e2e ONLY. The API refuses to boot
# with this in the Production environment. CI sets it true for the e2e job.
AUTH_ENABLE_MOCK_EXTERNAL=false

# Real OAuth + Turnstile creds (Sprint 2, HUMAN-CHECKLIST). Empty = that
# provider/check is simply off; the code paths are config-gated.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Do NOT set GIT_SHA here. The deploy pipeline/scripts export it; local dev
# defaults to "local" via docker-compose.yml. A value here would override the
# real SHA baked into prod images and break the deploy health check.
