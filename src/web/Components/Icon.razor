@* Outline icons in the Tabler visual grammar (24x24, stroke 2, round caps,
   currentColor) rendered as inline SVG — the official Tabler webfont is part
   of HUMAN-CHECKLIST 14 (self-hosted assets; no CDN). Names match the ti-*
   names DESIGN-REFERENCE.md calls for so the swap is mechanical.
   Decorative by default (aria-hidden) per the design reference; pass Label
   for meaningful icons. NO EMOJI anywhere in the product. *@

<svg xmlns="http://www.w3.org/2000/svg"
     width="@Size" height="@Size" viewBox="0 0 24 24"
     fill="none" stroke="currentColor" stroke-width="2"
     stroke-linecap="round" stroke-linejoin="round"
     class="bb-icon @Class"
     aria-hidden="@(Label is null ? "true" : null)"
     role="@(Label is null ? null : "img")"
     aria-label="@Label">
    @((MarkupString)PathMarkup)
</svg>

@code {
    [Parameter, EditorRequired] public string Name { get; set; } = "";
    [Parameter] public int Size { get; set; } = 20;
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Label { get; set; }

