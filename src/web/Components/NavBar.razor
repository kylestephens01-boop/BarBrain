@* Bottom nav (DESIGN-REFERENCE global rules): Home, Feed, Matches, Search,
   Venues, Profile. Active = --bb-synapse. 44px tap targets. Venues routes to
   a placeholder page until Sprint 5. *@
@inject NavigationManager Nav
@implements IDisposable

<nav class="bb-nav" aria-label="Main">
    @foreach (var item in Items)
    {
        <NavLink class="bb-nav__item" href="@item.Href"
                 Match="@(item.Href == "" ? NavLinkMatch.All : NavLinkMatch.Prefix)"
                 data-testid="@item.TestId">
            <Icon Name="@item.Icon" Size="22" />
            <span class="bb-nav__label">@item.Label</span>
        </NavLink>
    }
</nav>

@code {
    private sealed record NavItem(string Href, string Icon, string Label, string? TestId = null);

    private static readonly NavItem[] Items =
    [
        new("", "home", "Home"),
        new("feed", "sparkles", "Feed"),
        new("matches", "users", "Matches", "nav-matches"),
        new("search", "search", "Search"),
        new("venues", "map-pin", "Venues"),
        new("profile", "user", "Profile"),
    ];

    protected override void OnInitialized() => Nav.LocationChanged += OnLocationChanged;

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => StateHasChanged();

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
